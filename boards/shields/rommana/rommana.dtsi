#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    physical_layout: physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        input = <&kscan>;
        transform = <&default_transform>;
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 106 100    0  116  (-800)    53   166>
            , <&key_physical_attrs 106 100  116   32  (-300)   169    82>
            , <&key_physical_attrs 106 100  234    0       0     0     0>
            , <&key_physical_attrs 106 100  343   26       0     0     0>
            , <&key_physical_attrs 106 100  452   77       0     0     0>
            , <&key_physical_attrs 106 100  748   77       0     0     0>
            , <&key_physical_attrs 106 100  857   26       0     0     0>
            , <&key_physical_attrs 106 100  966    0       0     0     0>
            , <&key_physical_attrs 106 100 1084   32     300  1137    82>
            , <&key_physical_attrs 106 100 1200  116     800  1253   166>
            , <&key_physical_attrs 106 100   14  218  (-800)    67   268>
            , <&key_physical_attrs 106 100  122  134  (-300)   174   184>
            , <&key_physical_attrs 106 100  234  103       0     0     0>
            , <&key_physical_attrs 106 100  343  129       0     0     0>
            , <&key_physical_attrs 106 100  452  180       0     0     0>
            , <&key_physical_attrs 106 100  748  180       0     0     0>
            , <&key_physical_attrs 106 100  857  129       0     0     0>
            , <&key_physical_attrs 106 100  966  103       0     0     0>
            , <&key_physical_attrs 106 100 1078  134     300  1132   184>
            , <&key_physical_attrs 106 100 1186  218     800  1239   268>
            , <&key_physical_attrs 106 100  127  237  (-300)   180   287>
            , <&key_physical_attrs 106 100  234  206       0     0     0>
            , <&key_physical_attrs 106 100  343  232       0     0     0>
            , <&key_physical_attrs 106 100  857  232       0     0     0>
            , <&key_physical_attrs 106 100  966  206       0     0     0>
            , <&key_physical_attrs 106 100 1073  237     300  1126   287>
            , <&key_physical_attrs 106 100  370  361       0     0     0>
            , <&key_physical_attrs 106 100  479  387       0     0     0>
            , <&key_physical_attrs 106 100  721  387       0     0     0>
            , <&key_physical_attrs 106 100  830  361       0     0     0>
            ;
    };

    chosen {
        zmk,physical-layout = &physical_layout;
    };

    default_transform: keymap_transform {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)   RC(0,9) RC(0,8) RC(0,7) RC(0,6) RC(0,5)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)   RC(1,9) RC(1,8) RC(1,7) RC(1,6) RC(1,5)
        RC(2,0) RC(2,1) RC(2,2)                   RC(2,7) RC(2,6) RC(2,5)
                        RC(2,3) RC(2,4)   RC(2,9) RC(2,8)
        >;
    };

    kscan: kscan {
        compatible = "gpio-kbd-matrix";
        col-drive-inactive;
        settle-time-us = <0>;
        no-ghostkey-check;
        wakeup-source;
    };

    bootloader_key_left: bootloader_key_left {
        compatible = "zmk,boot-magic-key";
        key-position = <0>;
        jump-to-bootloader;
        status = "disabled";
    };
    bootloader_key_right: bootloader_key_right {
        compatible = "zmk,boot-magic-key";
        key-position = <9>;
        jump-to-bootloader;
        status = "disabled";
    };
};
